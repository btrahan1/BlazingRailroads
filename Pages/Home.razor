    private MarkupString GetTownBuildingsSummary(string townName)
    {
        if (!townLayouts.ContainsKey(townName) || townLayouts[townName].Count == 0)
        {
            return (MarkupString)"No buildings built yet.";
        }

        var buildings = townLayouts[townName];
        var summary = new List<string>();

        int hotels = buildings.Count(b => b.Type == "hotel");
        int stores = buildings.Count(b => b.Type == "general_store");
        int saloons = buildings.Count(b => b.Type == "saloon");
        int mines = buildings.Count(b => b.Type == "coal_mine");
        int derricks = buildings.Count(b => b.Type == "oil_derrick");

        if (hotels > 0) summary.Add($"{hotels} Hotel{(hotels > 1 ? "s" : "")}");
        if (stores > 0) summary.Add($"{stores} General Store{(stores > 1 ? "s" : "")}");
        if (saloons > 0) summary.Add($"{saloons} Saloon{(saloons > 1 ? "s" : "")}");
        if (mines > 0) summary.Add($"{mines} Coal Mine{(mines > 1 ? "s" : "")}");
        if (derricks > 0) summary.Add($"{derricks} Oil Derrick{(derricks > 1 ? "s" : "")}");

        return (MarkupString)string.Join("<br/>", summary); 
    }

    private async Task TravelToTown(Town destination)
    {
        if (destination == currentTown) return;

        bool hasCoal = await JSRuntime.InvokeAsync<bool>("window.railroadEngine.hasCoalTender");
        if (!hasCoal)
        {
            errorMessage = "You need coal to travel!";
            StateHasChanged();
            
            // clear after 3 seconds
            _ = Task.Run(async () =>
            {
                await Task.Delay(3000);
                errorMessage = "";
                await InvokeAsync(StateHasChanged);
            });
            return;
        }
        
        errorMessage = "";
        isMapVisible = false;
        StateHasChanged(); // Hide map

        // Wait for the train to leave town. JS will resolve the promise while the screen is black.
        await JSRuntime.InvokeVoidAsync("window.railroadEngine.beginTravel", destination.Name);
        
        // Now safely arrived at destination
        currentTown = destination;

        // Calculate Passive Income upon arrival
        int globalHotels = 0;
        int globalStores = 0;
        int globalSaloons = 0;
        int globalCoalMines = 0;
        foreach (var townLayout in townLayouts.Values)
        {
            globalHotels += townLayout.Count(b => b.Type == "hotel");
            globalStores += townLayout.Count(b => b.Type == "general_store");
            globalSaloons += townLayout.Count(b => b.Type == "saloon");
            globalCoalMines += townLayout.Count(b => b.Type == "coal_mine");
        }

        int passiveIncome = (globalHotels * 100) + (globalStores * 50) + (globalSaloons * 750) + (globalCoalMines * 200);
        if (passiveIncome > 0)
        {
            funds += passiveIncome;
            arrivalMessage = $"Funds received: ${passiveIncome} from business adventures!";
            
            _ = Task.Run(async () =>
            {
                await Task.Delay(4000);
                arrivalMessage = "";
                await InvokeAsync(StateHasChanged);
            });
        }

        await SaveGameAsync();
        StateHasChanged();

        // Load new town buildings while screen is transitioning
        if (townLayouts.ContainsKey(destination.Name))
        {
            await JSRuntime.InvokeVoidAsync("window.railroadEngine.loadTownBuildings", townLayouts[destination.Name]);
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("window.railroadEngine.loadTownBuildings", new List<BuildingData>());
        }
    }

