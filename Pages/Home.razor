@page "/"
@inject IJSRuntime JSRuntime

<PageTitle>Blazing Railroads</PageTitle>

<div style="width: 100vw; height: 100vh; overflow: hidden; margin: 0; padding: 0; position: relative;">
    <canvas id="renderCanvas" style="width: 100%; height: 100%; touch-action: none; outline: none;"></canvas>
    
    @if (currentState == GameState.MainMenu)
    {
        <div style="position: absolute; top: 0; left: 0; width: 100vw; height: 100vh; background-color: #2c3e50; display: flex; flex-direction: column; justify-content: center; align-items: center; z-index: 100;">
            <h1 style="color: #f1c40f; font-family: 'Times New Roman', serif; font-size: 5rem; margin-bottom: 50px; text-shadow: 3px 3px 6px #000;">Blazing Railroads</h1>
            <button @onclick="StartNewGame" style="padding: 15px 40px; font-size: 1.5rem; cursor: pointer; background-color: #27ae60; color: white; border: none; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.5); margin-bottom: 20px;">
                Start New Game
            </button>
            @if (hasSaveGame)
            {
                <button @onclick="ContinueGame" style="padding: 15px 40px; font-size: 1.5rem; cursor: pointer; background-color: #2980b9; color: white; border: none; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.5);">
                    Continue
                </button>
            }
        </div>
    }

    @if (currentState == GameState.InGame)
    {
        <div style="position: absolute; bottom: 30px; left: 30px; display: flex; flex-direction: column; gap: 10px; z-index: 10; background: rgba(0,0,0,0.6); padding: 15px; border-radius: 10px; color: white; font-family: 'Times New Roman', serif;">
            <h2 style="margin: 0; font-size: 2rem; color: #f1c40f;">$@funds</h2>
            <h4 style="margin: 0; font-size: 1.2rem; color: #ecf0f1;">Train Capacity: @currentCarCount / @MAX_CARS</h4>
            <button @onclick="UnloadTrain" disabled="@(currentCarCount == 0)" style="margin-top: 10px; padding: 10px; font-size: 1.2rem; cursor: pointer; background-color: #e74c3c; color: white; border: none; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.3); font-weight: bold;">
                💰 UNLOAD TRAIN
            </button>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div style="position: absolute; top: 120px; left: 50%; transform: translateX(-50%); background-color: rgba(231, 76, 60, 0.9); padding: 15px 30px; border-radius: 8px; color: white; font-family: 'Times New Roman', serif; font-size: 1.5rem; font-weight: bold; border: 2px solid #c0392b; z-index: 20; box-shadow: 0 4px 6px rgba(0,0,0,0.5);">
                @errorMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(arrivalMessage))
        {
            <div style="position: absolute; top: 200px; left: 50%; transform: translateX(-50%); background-color: rgba(46, 204, 113, 0.9); padding: 15px 30px; border-radius: 8px; color: white; font-family: 'Times New Roman', serif; font-size: 1.5rem; font-weight: bold; border: 2px solid #27ae60; z-index: 20; box-shadow: 0 4px 6px rgba(0,0,0,0.5);">
                @arrivalMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(buildingMessage))
        {
            <div style="position: absolute; top: 280px; left: 50%; transform: translateX(-50%); background-color: rgba(52, 152, 219, 0.9); padding: 15px 30px; border-radius: 8px; color: white; font-family: 'Times New Roman', serif; font-size: 1.5rem; font-weight: bold; border: 2px solid #2980b9; z-index: 20; box-shadow: 0 4px 6px rgba(0,0,0,0.5);">
                🚧 @buildingMessage
            </div>
        }

    <div style="position: absolute; top: 30px; right: 30px; display: flex; flex-direction: column; gap: 10px; z-index: 10;">
        <button @onclick="BuildHotel" disabled="@(funds < COST_HOTEL)" style="padding: 10px 20px; font-size: 1.2rem; cursor: pointer; background-color: #f1c40f; color: #2c3e50; border: 2px solid #f39c12; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.5); font-weight: bold;">
            🏗️ Build Hotel ($@COST_HOTEL)
        </button>
        <button @onclick="BuildGeneralStore" disabled="@(funds < COST_GENERAL_STORE)" style="padding: 10px 20px; font-size: 1.2rem; cursor: pointer; background-color: #1abc9c; color: white; border: 2px solid #16a085; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.5); font-weight: bold;">
            🏪 Build General Store ($@COST_GENERAL_STORE)
        </button>
        <button @onclick="BuildSaloon" disabled="@(funds < COST_SALOON)" style="padding: 10px 20px; font-size: 1.2rem; cursor: pointer; background-color: #d35400; color: white; border: 2px solid #e67e22; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.5); font-weight: bold;">
            🍺 Build Saloon ($@COST_SALOON)
        </button>
        <button @onclick="BuildCoalMine" disabled="@(funds < COST_COAL_MINE)" style="padding: 10px 20px; font-size: 1.2rem; cursor: pointer; background-color: #34495e; color: white; border: 2px solid #2c3e50; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.5); font-weight: bold;">
            ⛏️ Build Coal Mine ($@COST_COAL_MINE)
        </button>
        <button @onclick="BuildOilDerrick" disabled="@(funds < COST_OIL_DERRICK)" style="padding: 10px 20px; font-size: 1.2rem; cursor: pointer; background-color: #000000; color: white; border: 2px solid #333333; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.5); font-weight: bold;">
            🛢️ Build Oil Derrick ($@COST_OIL_DERRICK)
        </button>
        <span style="color: white; font-family: 'Times New Roman', serif; text-shadow: 1px 1px 2px black; font-size: 0.9rem; text-align: center;">
            (Press 'R' to Rotate, 'ESC' to Cancel)
        </span>
    </div>

    <div style="position: absolute; bottom: 30px; right: 30px; display: flex; flex-direction: column; gap: 10px; z-index: 10;">
        <button @onclick="ToggleMap" style="padding: 10px 20px; font-size: 1.2rem; cursor: pointer; background-color: #f39c12; color: #fff; border: 2px solid #e67e22; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.5); font-weight: bold;">
            🗺️ Open Travel Map
        </button>
        <button @onclick="AddCoalTender" disabled="@(funds < GetCoalCost() || currentCarCount >= MAX_CARS)" style="padding: 10px 20px; font-size: 1rem; cursor: pointer; background-color: #8e44ad; color: white; border: none; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.3);">
            + Add Coal Tender ($@GetCoalCost())
        </button>
        <button @onclick="AddPassengerCar" disabled="@(funds < COST_PASSENGER || currentCarCount >= MAX_CARS)" style="padding: 10px 20px; font-size: 1rem; cursor: pointer; background-color: #27ae60; color: white; border: none; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.3);">
            + Add Passenger Car ($@COST_PASSENGER)
        </button>
        <button @onclick="AddOilTankCar" disabled="@(funds < COST_OIL || currentCarCount >= MAX_CARS || !HasOilDerrickInCurrentTown() || currentOilCarCount >= 2)" style="padding: 10px 20px; font-size: 1rem; cursor: pointer; background-color: #2980b9; color: white; border: none; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.3);">
            + Add Oil Tank Car ($@COST_OIL)
        </button>
        <button @onclick="AddFreightBoxcar" disabled="@(funds < COST_FREIGHT || currentCarCount >= MAX_CARS)" style="padding: 10px 20px; font-size: 1rem; cursor: pointer; background-color: #d35400; color: white; border: none; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.3);">
            + Add Freight Boxcar ($@COST_FREIGHT)
        </button>
        <button @onclick="AddFirstClassCar" disabled="@(funds < COST_FIRST_CLASS || currentCarCount >= MAX_CARS || hasFirstClassCar || !HasHotelInCurrentTown())" style="padding: 10px 20px; font-size: 1rem; cursor: pointer; background-color: #9b59b6; color: white; border: none; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.3);">
            + Add First Class Coach ($@COST_FIRST_CLASS)
        </button>
        <button @onclick="RemoveSelectedCar" style="padding: 10px 20px; font-size: 1rem; cursor: pointer; background-color: #c0392b; color: white; border: none; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.3);">
            - Remove Selected Car
        </button>
        <button @onclick="StartSimulation" style="padding: 15px 30px; font-size: 1.2rem; cursor: pointer; background-color: #2c3e50; color: white; border: none; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.3); margin-top: 10px;">
            START
        </button>
    </div>

    @if (isMapVisible)
    {
        <div class="map-overlay">
            <div class="map-container">
                <button class="close-map-btn" @onclick="ToggleMap">X</button>

                <!-- SVG Overlay for Routes -->
                <svg width="100%" height="100%" style="position: absolute; top: 0; left: 0; pointer-events: none; z-index: 0;">
                    @foreach (var route in routes)
                    {
                        var tA = towns.FirstOrDefault(t => t.Name == route.CityA);
                        var tB = towns.FirstOrDefault(t => t.Name == route.CityB);
                        if (tA != null && tB != null)
                        {
                            bool isRouteConnected = tA.IsConnected && tB.IsConnected;
                            string strokeColor = isRouteConnected ? "#3498db" : "rgba(128, 128, 128, 0.5)";
                            int strokeWidth = isRouteConnected ? 4 : 2;
                            string strokeDash = isRouteConnected ? "none" : "5, 5";

                            <line x1="@tA.Left" y1="@tA.Top" x2="@tB.Left" y2="@tB.Top" 
                                  stroke="@strokeColor" stroke-width="@strokeWidth" stroke-dasharray="@strokeDash" />
                        }
                    }
                </svg>

                @foreach (var town in towns)
                {
                    <div class="town-node @(town == currentTown ? "current" : "")" 
                         style="top: @town.Top; left: @town.Left; position: absolute; display: flex; flex-direction: column; align-items: center; cursor: pointer; z-index: 1;" 
                         @onclick="() => HandleTownClick(town)"
                         @onmouseover="() => ShowTownTooltip(town)"
                         @onmouseout="HideTownTooltip">
                        
                        @if (town.IsConnected) {
                            <div style="width: 20px; height: 20px; background-color: @(currentTown?.Name == town.Name ? "#e74c3c" : "#3498db"); border-radius: 50%; border: 3px solid white; box-shadow: 0 0 10px rgba(0,0,0,0.8);"></div>
                        } else {
                            <div style="width: 20px; height: 20px; background-color: gray; border-radius: 50%; border: 3px solid #ccc; box-shadow: 0 0 10px rgba(0,0,0,0.8);"></div>
                        }

                        <span class="town-label" style="color: @(town.IsConnected ? "white" : "gray"); font-family: 'Times New Roman', serif; font-size: 1.2rem; font-weight: bold; text-shadow: 2px 2px 4px black; margin-top: 5px; white-space: nowrap;">@town.Name</span>
                        
                        @if (hoveredTown?.Name == town.Name)
                        {
                            <div style="position: absolute; top: -100%; left: 50%; transform: translate(-50%, -10px); background-color: rgba(0, 0, 0, 0.9); color: white; padding: 15px; border-radius: 8px; border: 2px solid #f39c12; white-space: nowrap; z-index: 100; font-family: 'Courier New', Courier, monospace; pointer-events: none; text-align: left; box-shadow: 0 4px 6px rgba(0,0,0,0.5);">
                                <strong style="color: #f39c12; font-size: 1.1rem; border-bottom: 1px solid #f39c12; padding-bottom: 5px; margin-bottom: 5px; display: block;">@town.Name Buildings</strong>
                                @if (!town.IsConnected) {
                                    <span style="color: #ccc;">Unconnected (Click to Build Track for $2500)</span>
                                } else {
                                    @GetTownBuildingsSummary(town.Name)
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
    }
</div>

@code {
    public enum GameState
    {
        MainMenu,
        InGame
    }
    
    private GameState currentState = GameState.MainMenu;
    private bool hasSaveGame = false;
    private bool isMapVisible = false;
    private Town currentTown;
    private Town hoveredTown;
    private string errorMessage = "";
    private string arrivalMessage = "";
    private string buildingMessage = "";
    private bool isBuildingTrack = false;
    private bool gameWon = false;
    
    // Economy
    private int funds = 1000;
    private int currentCarCount = 0;
    private int currentOilCarCount = 0;
    private bool hasFirstClassCar = false;
    private const int MAX_CARS = 5;

    public class BuildingData
    {
        public string Type { get; set; } = "";
        public float X { get; set; }
        public float Y { get; set; }
        public float Z { get; set; }
        public float RotY { get; set; }
    }

    private Dictionary<string, List<BuildingData>> townLayouts = new();

    public class GameSaveData
    {
        public int Funds { get; set; }
        public string CurrentTown { get; set; } = "";
        public List<string> TrainLoadout { get; set; } = new();
        public Dictionary<string, List<BuildingData>> TownLayouts { get; set; } = new();
        public List<string> UnlockedTowns { get; set; } = new();
    }

    // Car Costs
    private const int COST_COAL = 100;
    private const int COST_PASSENGER = 0;
    private const int COST_FREIGHT = 100;
    private const int COST_OIL = 100;
    private const int COST_FIRST_CLASS = 0;
    private const int COST_HOTEL = 1000;
    private const int COST_GENERAL_STORE = 500;
    private const int COST_SALOON = 250;
    private const int COST_COAL_MINE = 2000;
    private const int COST_OIL_DERRICK = 1500;

    private class Town
    {
        public string Name { get; set; } = "";
        public string Top { get; set; } = "";
        public string Left { get; set; } = "";
        public bool IsConnected { get; set; } = true;
    }

    private List<Town> towns = new()
    {
        new Town { Name = "St. Joseph", Top = "45%", Left = "55%", IsConnected = true },
        new Town { Name = "Omaha", Top = "42%", Left = "53%", IsConnected = true },
        new Town { Name = "Cheyenne", Top = "38%", Left = "35%", IsConnected = true },
        new Town { Name = "Denver", Top = "48%", Left = "33%", IsConnected = true },
        new Town { Name = "Salt Lake City", Top = "35%", Left = "22%", IsConnected = true },
        new Town { Name = "Sacramento", Top = "45%", Left = "10%", IsConnected = true },
        new Town { Name = "San Francisco", Top = "52%", Left = "5%", IsConnected = false },
        new Town { Name = "Los Angeles", Top = "68%", Left = "12%", IsConnected = false },
        new Town { Name = "Santa Fe", Top = "65%", Left = "35%", IsConnected = false },
        new Town { Name = "El Paso", Top = "82%", Left = "38%", IsConnected = false },
        new Town { Name = "Dodge City", Top = "58%", Left = "48%", IsConnected = false },
        new Town { Name = "Dallas", Top = "75%", Left = "50%", IsConnected = false },
        new Town { Name = "Houston", Top = "85%", Left = "52%", IsConnected = false },
        new Town { Name = "Kansas City", Top = "50%", Left = "58%", IsConnected = false },
        new Town { Name = "St. Louis", Top = "48%", Left = "68%", IsConnected = false },
        new Town { Name = "Chicago", Top = "32%", Left = "68%", IsConnected = false },
        new Town { Name = "New York", Top = "45%", Left = "85%", IsConnected = false }
    };

    private class Route
    {
        public string CityA { get; set; } = "";
        public string CityB { get; set; } = "";
    }

    private List<Route> routes = new()
    {
        // Initial Connected Routes (Spine)
        new Route { CityA = "Sacramento", CityB = "Salt Lake City" },
        new Route { CityA = "Salt Lake City", CityB = "Cheyenne" },
        new Route { CityA = "Cheyenne", CityB = "Denver" },
        new Route { CityA = "Cheyenne", CityB = "Omaha" },
        new Route { CityA = "Denver", CityB = "Omaha" },
        new Route { CityA = "Omaha", CityB = "St. Joseph" },

        // Expansion Routes (West)
        new Route { CityA = "Sacramento", CityB = "San Francisco" },
        new Route { CityA = "Sacramento", CityB = "Los Angeles" },
        new Route { CityA = "Salt Lake City", CityB = "Los Angeles" },
        new Route { CityA = "Los Angeles", CityB = "Santa Fe" },
        new Route { CityA = "Denver", CityB = "Santa Fe" },
        new Route { CityA = "Santa Fe", CityB = "El Paso" },
        
        // Expansion Routes (Midwest/South)
        new Route { CityA = "El Paso", CityB = "Dallas" },
        new Route { CityA = "Santa Fe", CityB = "Dodge City" },
        new Route { CityA = "Denver", CityB = "Dodge City" },
        new Route { CityA = "Dodge City", CityB = "Dallas" },
        new Route { CityA = "Dallas", CityB = "Houston" },
        new Route { CityA = "Dodge City", CityB = "Kansas City" },
        new Route { CityA = "St. Joseph", CityB = "Kansas City" },
        
        // Expansion Routes (East)
        new Route { CityA = "Kansas City", CityB = "St. Louis" },
        new Route { CityA = "St. Louis", CityB = "Chicago" },
        new Route { CityA = "Omaha", CityB = "Chicago" },
        new Route { CityA = "Chicago", CityB = "New York" },
        new Route { CityA = "St. Louis", CityB = "New York" }
    };

    public static Action<string, string, float, float, float, float> OnBuildingPlacedAction;
    public static Action<string, float, float, float> OnBuildingRemovedAction;

    [JSInvokable]
    public static void OnBuildingPlaced(string town, string type, float x, float y, float z, float rotY)
    {
        OnBuildingPlacedAction?.Invoke(town, type, x, y, z, rotY);
    }

    [JSInvokable]
    public static void OnBuildingRemoved(string town, float x, float y, float z)
    {
        OnBuildingRemovedAction?.Invoke(town, x, y, z);
    }

    protected override void OnInitialized()
    {
        currentTown = towns.First(t => t.Name == "Sacramento");
        OnBuildingPlacedAction = HandleBuildingPlaced;
        OnBuildingRemovedAction = HandleBuildingRemoved;
    }

    private bool HasHotelInCurrentTown()
    {
        if (currentTown == null) return false;
        return townLayouts.ContainsKey(currentTown.Name) && townLayouts[currentTown.Name].Any(b => b.Type == "hotel");
    }

    private bool HasCoalMineInCurrentTown()
    {
        if (currentTown == null) return false;
        return townLayouts.ContainsKey(currentTown.Name) && townLayouts[currentTown.Name].Any(b => b.Type == "coal_mine");
    }

    private bool HasOilDerrickInCurrentTown()
    {
        if (currentTown == null) return false;
        return townLayouts.ContainsKey(currentTown.Name) && townLayouts[currentTown.Name].Any(b => b.Type == "oil_derrick");
    }

    private int GetCoalCost()
    {
        return HasCoalMineInCurrentTown() ? 0 : COST_COAL;
    }

    private void HandleBuildingPlaced(string town, string type, float x, float y, float z, float rotY)
    {
        int cost = 0;
        if (type == "hotel") cost = COST_HOTEL;
        else if (type == "general_store") cost = COST_GENERAL_STORE;
        else if (type == "saloon") cost = COST_SALOON;
        else if (type == "coal_mine") cost = COST_COAL_MINE;
        else if (type == "oil_derrick") cost = COST_OIL_DERRICK;

        if (funds >= cost)
        {
            funds -= cost;

            if (!townLayouts.ContainsKey(town))
                townLayouts[town] = new List<BuildingData>();

            townLayouts[town].Add(new BuildingData { Type = type, X = x, Y = y, Z = z, RotY = rotY });

            _ = InvokeAsync(async () =>
            {
                await SaveGameAsync();
                StateHasChanged();
            });
        }
    }

    private void HandleBuildingRemoved(string town, float x, float y, float z)
    {
        if (townLayouts.ContainsKey(town))
        {
            var list = townLayouts[town];
            var toRemove = list.OrderBy(b => Math.Abs(b.X - x) + Math.Abs(b.Y - y) + Math.Abs(b.Z - z)).FirstOrDefault();
            if (toRemove != null && (Math.Abs(toRemove.X - x) < 0.1f)) // sanity check
            {
                list.Remove(toRemove);
                if (toRemove.Type == "hotel") funds += COST_HOTEL;
                else if (toRemove.Type == "general_store") funds += COST_GENERAL_STORE;
                else if (toRemove.Type == "saloon") funds += COST_SALOON;
                else if (toRemove.Type == "coal_mine") funds += COST_COAL_MINE;
                else if (toRemove.Type == "oil_derrick") funds += COST_OIL_DERRICK;

                _ = InvokeAsync(async () =>
                {
                    await SaveGameAsync();
                    StateHasChanged();
                });
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var saveJson = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "blazingRailroadsSave");
            if (!string.IsNullOrEmpty(saveJson))
            {
                hasSaveGame = true;
                StateHasChanged();
            }
        }
    }

    private async Task StartNewGame()
    {
        funds = 1000;
        currentTown = towns.First(t => t.Name == "Sacramento");
        townLayouts = new Dictionary<string, List<BuildingData>>();
        currentState = GameState.InGame;
        StateHasChanged();
        
        // Wait a small tick so DOM can register the hidden overlay / canvas focus
        await Task.Delay(50);
        await JSRuntime.InvokeVoidAsync("window.railroadEngine.init", "renderCanvas", currentTown.Name);
        await UpdateCarCount();
        await SaveGameAsync();
    }

    private async Task ContinueGame()
    {
        var saveJson = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "blazingRailroadsSave");
        if (!string.IsNullOrEmpty(saveJson))
        {
            var saveData = System.Text.Json.JsonSerializer.Deserialize<GameSaveData>(saveJson);
            if (saveData != null)
            {
                funds = saveData.Funds;
                currentTown = towns.FirstOrDefault(t => t.Name == saveData.CurrentTown) ?? towns.First();
                
                if (saveData.UnlockedTowns != null && saveData.UnlockedTowns.Count > 0)
                {
                    foreach(var t in towns)
                    {
                        if (saveData.UnlockedTowns.Contains(t.Name)) t.IsConnected = true;
                    }
                }

                currentState = GameState.InGame;
                StateHasChanged(); 

                await Task.Delay(50);
                await JSRuntime.InvokeVoidAsync("window.railroadEngine.init", "renderCanvas", currentTown.Name);
                
                if (saveData.TrainLoadout != null && saveData.TrainLoadout.Count > 0)
                {
                    await JSRuntime.InvokeVoidAsync("window.railroadEngine.restoreTrain", saveData.TrainLoadout);
                }

                if (saveData.TownLayouts != null)
                {
                    townLayouts = saveData.TownLayouts;
                    if (townLayouts.ContainsKey(currentTown.Name))
                    {
                        await JSRuntime.InvokeVoidAsync("window.railroadEngine.loadTownBuildings", townLayouts[currentTown.Name]);
                    }
                }

                await UpdateCarCount(); 
            }
        }
    }

    private async Task SaveGameAsync()
    {
        var loadout = await JSRuntime.InvokeAsync<List<string>>("window.railroadEngine.getTrainLoadout");
        var saveData = new GameSaveData
        {
            Funds = funds,
            CurrentTown = currentTown.Name,
            TrainLoadout = loadout,
            TownLayouts = townLayouts,
            UnlockedTowns = towns.Where(t => t.IsConnected).Select(t => t.Name).ToList()
        };
        var json = System.Text.Json.JsonSerializer.Serialize(saveData);
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "blazingRailroadsSave", json);
    }

    private async Task StartSimulation()
    {
        await JSRuntime.InvokeVoidAsync("window.railroadEngine.startAnimation");
    }

    private void ToggleMap()
    {
        if (isBuildingTrack) return;
        isMapVisible = !isMapVisible;
        errorMessage = ""; // Clear errors when interacting with UI
        hoveredTown = null;
    }

    private async Task HandleTownClick(Town town)
    {
        if (isBuildingTrack) return;

        if (town.IsConnected)
        {
            await TravelToTown(town);
        }
        else
        {
            // Verify Adjacency
            bool canConnect = routes.Any(r => 
                (r.CityA == town.Name && towns.First(t => t.Name == r.CityB).IsConnected) || 
                (r.CityB == town.Name && towns.First(t => t.Name == r.CityA).IsConnected));

            if (!canConnect)
            {
                errorMessage = "You can only build track to adjacent connected regions!";
                _ = Task.Run(async () =>
                {
                    await Task.Delay(3000);
                    errorMessage = "";
                    await InvokeAsync(StateHasChanged);
                });
                return;
            }

            if (funds >= 2500)
            {
                await BuildTrackToTown(town);
            }
            else
            {
                errorMessage = "Not enough funds to build new track. Costs $2500.";
                _ = Task.Run(async () =>
                {
                    await Task.Delay(3000);
                    errorMessage = "";
                    await InvokeAsync(StateHasChanged);
                });
            }
        }
    }

    private async Task BuildTrackToTown(Town town)
    {
        isMapVisible = false; // Hide map to show building UI
        funds -= 2500;
        isBuildingTrack = true;
        errorMessage = "";
        
        for (int i = 30; i > 0; i--)
        {
            buildingMessage = $"Building railway to {town.Name}... ({i}s left)";
            StateHasChanged();
            await Task.Delay(1000);
        }

        town.IsConnected = true;
        isBuildingTrack = false;
        buildingMessage = "";
        arrivalMessage = $"Town {town.Name} is now connected to the railway system!";
        StateHasChanged();

        await SaveGameAsync();

        CheckWinCondition();

        _ = Task.Run(async () =>
        {
            await Task.Delay(5000);
            arrivalMessage = "";
            await InvokeAsync(StateHasChanged);
        });
    }

    private void CheckWinCondition()
    {
        if (gameWon) return; // Already won

        // BFS to find path from New York to San Francisco
        var nY = towns.FirstOrDefault(t => t.Name == "New York");
        var sF = towns.FirstOrDefault(t => t.Name == "San Francisco");

        if (nY == null || !nY.IsConnected || sF == null || !sF.IsConnected) return;

        var queue = new Queue<string>();
        var visited = new HashSet<string>();
        
        queue.Enqueue(nY.Name);
        visited.Add(nY.Name);

        while(queue.Count > 0)
        {
            var curr = queue.Dequeue();
            if (curr == sF.Name) 
            {
                TriggerWin();
                return;
            }

            // Find all connected neighbors
            var neighbors = routes.Where(r => r.CityA == curr || r.CityB == curr)
                                  .Select(r => r.CityA == curr ? r.CityB : r.CityA)
                                  .Where(n => !visited.Contains(n) && towns.First(t => t.Name == n).IsConnected);
            
            foreach(var neighbor in neighbors)
            {
                visited.Add(neighbor);
                queue.Enqueue(neighbor);
            }
        }
    }

    private void TriggerWin()
    {
        gameWon = true;
        funds += 1000000;
        arrivalMessage = "TRANSCONTINENTAL RAILROAD COMPLETED! You received a $1,000,000 Bonus! You win!";
        StateHasChanged();
        _ = SaveGameAsync();
    }

