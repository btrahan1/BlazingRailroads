    private async Task UpdateCarCount()
    {
        // Simple JS eval to count active passengerCars array minus Caboose
        currentCarCount = await JSRuntime.InvokeAsync<int>("eval", "window.railroadEngine.passengerCars.filter(c => !c.isCaboose).length");
        hasFirstClassCar = await JSRuntime.InvokeAsync<bool>("window.railroadEngine.hasFirstClassCar");
        currentOilCarCount = await JSRuntime.InvokeAsync<int>("eval", "window.railroadEngine.passengerCars.filter(c => c.carType === 'oil').length");
        StateHasChanged();
    }

    private async Task UnloadTrain()
    {
        bool townHasOil = HasOilDerrickInCurrentTown();
        var revenues = await JSRuntime.InvokeAsync<List<CarRevenue>>("window.railroadEngine.getRevenueCars", townHasOil);
        int totalPayout = 0;
        foreach (var car in revenues)
        {
            totalPayout += car.Payout;
        }

        // Even if payout is 0, we still want to unload to consume coal
        if (totalPayout > 0 || currentCarCount > 0)
        {
            funds += totalPayout;
            await JSRuntime.InvokeVoidAsync("window.railroadEngine.unloadCars", townHasOil);
            await UpdateCarCount();
            await SaveGameAsync();
            errorMessage = ""; // clear possible coal warnings
        }
    }

    private class CarRevenue
    {
        public string Type { get; set; } = "";
        public int Payout { get; set; }
    }
